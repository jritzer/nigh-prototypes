        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Polygon-based geographic boundary for venues like stadiums, parks, and campuses. More accurate than circular radius for irregularly shaped venues. Includes GPS validation and mock location detection.</w:t>
