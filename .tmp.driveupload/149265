          <w:numId w:val="2"/>
        </w:numPr>
        <w:spacing w:after="60"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Local restaurant wants only nearby diners to reserve</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="ListParagraph"/>
