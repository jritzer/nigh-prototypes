    <w:p>
      <w:pPr>
        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Collections are curated bundles of related Drops organized around a shared theme, campaign, venue, or moment. A Collection is NOT a Drop itself -- it is a container that groups multiple independently-managed Drops for cohesive discovery and promotion.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="80"/>
      </w:pPr>
    </w:p>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="Heading2"/>
