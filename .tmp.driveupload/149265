      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Handle is claimed at the moment of first account creation</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="ListParagraph"/>
        <w:numPr>
