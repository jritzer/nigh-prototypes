    <w:p>
      <w:pPr>
        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Support Tools are internal-only applications used by Nigh's support and operations team. They are NOT accessible to consumers, Org staff, or Enterprise users. All support actions are logged, attributed to the performing agent, timestamped, and stored immutably.</w:t>
