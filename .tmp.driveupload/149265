            <w:r>
              <w:rPr>
                <w:sz w:val="20"/>
                <w:szCs w:val="20"/>
              </w:rPr>
              <w:t xml:space="preserve">Array of AuditEntry, immutable</w:t>
            </w:r>
          </w:p>
