      <w:pPr>
        <w:pStyle w:val="ListParagraph"/>
        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="2"/>
        </w:numPr>
        <w:spacing w:after="60"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">AC-14.11.4: All rejection, suspension, and ban actions are logged in the immutable audit log.</w:t>
      </w:r>
