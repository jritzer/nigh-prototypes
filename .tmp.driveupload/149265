          <w:ilvl w:val="1"/>
          <w:numId w:val="2"/>
        </w:numPr>
        <w:spacing w:after="60"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Host can check in all 3 via &quot;Check In All&quot; or individually.</w:t>
      </w:r>
