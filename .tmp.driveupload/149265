        <w:t xml:space="preserve">14.10 CSV Guest List Import</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Hosts can import existing guest/customer lists via CSV to bootstrap their guest relationships on Nigh. This is particularly useful for businesses transitioning from other platforms or managing existing customer databases.</w:t>
      </w:r>
