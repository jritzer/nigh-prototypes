        <w:spacing w:after="60"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">This rule is enforced across all surfaces: Drops app, Pro app, Enterprise Web App, email, SMS, push notifications, and Niya AI responses.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
