        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">When a user with an existing personal account activates a Pro (business) account, the system recognizes their existing handle and offers one-tap confirmation. The user does not need to manually re-enter their handle.</w:t>
