        <w:t xml:space="preserve">16. Handle System and Links</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">The Handle System is the identity and link infrastructure that powers Nigh's URL structure, attribution tracking, and account identification. Handles are the public-facing identity for all accounts, and the link system ensures consistent, trackable, and secure access to Drops and accounts.</w:t>
      </w:r>
