        <w:numPr>
          <w:ilvl w:val="0"/>
          <w:numId w:val="2"/>
        </w:numPr>
        <w:spacing w:after="60"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Used for populating existing relationships and for 'Guest List Only' audience targeting</w:t>
      </w:r>
    </w:p>
    <w:p>
