        <w:t xml:space="preserve">16.1 Handle Assignment</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="120"/>
      </w:pPr>
      <w:r>
        <w:t xml:space="preserve">Handles are assigned during first account creation (phone OTP onboarding) and permanently locked to the verified phone number.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="80"/>
