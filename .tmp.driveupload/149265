        <w:t xml:space="preserve">1. Product Vision and Scope</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
        <w:spacing w:after="80"/>
      </w:pPr>
    </w:p>
    <w:p>
      <w:pPr>
